<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A009688"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Qui va jouer ? 🏓"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:gravity="center"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginEnd="8dp"
            android:background="#22FF0000">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔴 ÉQUIPE ROUGE"
                android:textColor="#FFCDD2"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <Spinner
                android:id="@+id/spinnerEq1Joueur1"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/labelEq1Joueur2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Joueur 2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/spinnerEq1Joueur2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#33FFFFFF"
                android:visibility="gone"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginStart="8dp"
            android:background="#220000FF">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔵 ÉQUIPE BLEUE"
                android:textColor="#BBDEFB"
                android:textStyle="bold"
                android:textSize="18sp"
                android:layout_marginBottom="12dp"/>

            <Spinner
                android:id="@+id/spinnerEq2Joueur1"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#33FFFFFF"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/labelEq2Joueur2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:text="Joueur 2"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/spinnerEq2Joueur2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="#33FFFFFF"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/btnLancerMatch"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="COMMENCER LE MATCH ⚡"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:textSize="18sp"
        android:layout_marginTop="24dp"/>

</LinearLayout>
