<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fond principal -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/backbois2"
        android:scaleType="fitXY" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="70dp"
        android:paddingLeft="60dp"
        android:paddingTop="40dp"
        android:paddingRight="65dp"
        android:paddingBottom="40dp">

        <!-- Titre -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="Qui va jouer ?"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- Conteneur équipes -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- ÉQUIPE ROUGE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/autrecouleurbois"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="ÉQUIPE ROUGE"
                    android:textColor="#FFCDD2"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerEq1Joueur1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerEq1Joueur2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerEq1Joueur3"
                    android:layout_width="match_parent"
                    android:layout_height="50dp" />

            </LinearLayout>

            <!-- ÉQUIPE BLEUE -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/backautrebois"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="ÉQUIPE BLEUE"
                    android:textColor="#BBDEFB"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerEq2Joueur1"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerEq2Joueur2"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginBottom="8dp" />

                <Spinner
                    android:id="@+id/spinnerEq2Joueur3"
                    android:layout_width="match_parent"
                    android:layout_height="50dp" />

            </LinearLayout>

        </LinearLayout>

        <CheckBox
            android:id="@+id/checkReplay"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="12dp"
            android:buttonTint="#FFFFFF"
            android:checked="true"
            android:fontFamily="serif"
            android:text="Activer les replays"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Bouton -->
        <!-- Bouton IMAGE -->
        <FrameLayout
            android:id="@+id/btnLancerMatch"
            android:layout_width="match_parent"
            android:layout_height="90dp"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/btnCommencer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/blancboutton"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                android:contentDescription="Commencer le match" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="COMMENCER LE MATCH"
                android:textColor="#2B1E1E"
                android:textSize="15dp"
                android:textStyle="bold" />

        </FrameLayout>

    </LinearLayout>

</FrameLayout>
