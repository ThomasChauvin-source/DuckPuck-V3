<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/backbois2" />

    <com.example.duckpuck.AssetPanelLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:assetInsetStyle="wood_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/qui_va_jouer"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="@drawable/autrecouleurbois"
                    android:orientation="vertical"
                    android:padding="@dimen/team_panel_inner_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/quipe_rouge"
                        android:textColor="#FFCDD2"
                        android:textSize="@dimen/section_title_text_size"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerEq1Joueur1"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spinner_height"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerEq1Joueur2"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spinner_height"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerEq1Joueur3"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spinner_height" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/backautrebois"
                    android:orientation="vertical"
                    android:padding="@dimen/team_panel_inner_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:text="@string/quipe_bleue"
                        android:textColor="#BBDEFB"
                        android:textSize="@dimen/section_title_text_size"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerEq2Joueur1"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spinner_height"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerEq2Joueur2"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spinner_height"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerEq2Joueur3"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/spinner_height" />

                </LinearLayout>

            </LinearLayout>

            <CheckBox
                android:id="@+id/checkReplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:buttonTint="#FFFFFF"
                android:checked="true"
                android:fontFamily="serif"
                android:text="@string/activer_les_replays"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/body_text_size"
                android:textStyle="bold" />

            <FrameLayout
                android:id="@+id/btnLancerMatch"
                android:layout_width="match_parent"
                android:layout_height="@dimen/action_button_height"
                android:layout_marginTop="20dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/btnCommencer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:contentDescription="Commencer le match"
                    android:scaleType="fitXY"
                    android:src="@drawable/blancboutton" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="@string/commencer_le_match"
                    android:textColor="#2B1E1E"
                    android:textSize="@dimen/body_text_size"
                    android:textStyle="bold" />

            </FrameLayout>

        </LinearLayout>

    </com.example.duckpuck.AssetPanelLayout>
</FrameLayout>
