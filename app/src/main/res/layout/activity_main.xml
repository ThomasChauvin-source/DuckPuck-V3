<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:scaleType="centerCrop"
        android:src="@drawable/game_bg" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:padding="40dp">

        <LinearLayout
            android:id="@+id/menuLateral"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_menu_border"
            android:elevation="6dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="8dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnJouer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:fontFamily="serif"
                android:text="Jouer"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_selector" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAjouterJoueur"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:fontFamily="serif"
                android:text="Ajouter un joueur"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_selector" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnHistorique"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:fontFamily="serif"
                android:text="Historique des parties"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_selector" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStatistiques"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="5dp"
                android:fontFamily="serif"
                android:text="Statistiques"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_selector" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnParametres"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="Paramètres"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:background="@drawable/bg_btn_selector" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragmentContainerView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2" />

    </LinearLayout>
</FrameLayout>