<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/backmenu" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gMenuStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.038" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gMenuEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.338" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gContentStart"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.355" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gContentEnd"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.962" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gTop"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.038" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/gBottom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.962" />

        <LinearLayout
            android:id="@+id/menuLateral"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/menu_button_padding_h"
            app:layout_constraintBottom_toTopOf="@id/gBottom"
            app:layout_constraintEnd_toStartOf="@id/gMenuEnd"
            app:layout_constraintStart_toStartOf="@id/gMenuStart"
            app:layout_constraintTop_toTopOf="@id/gTop">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnJouer"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_btn_selector"
                android:backgroundTint="@null"
                android:fontFamily="serif"
                android:paddingLeft="@dimen/menu_button_padding_h"
                android:paddingRight="@dimen/menu_button_padding_h"
                android:text="@string/menu_jouer"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/menu_button_text_size" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnAjouterJoueur"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_btn_selector"
                android:backgroundTint="@null"
                android:fontFamily="serif"
                android:paddingLeft="@dimen/menu_button_padding_h"
                android:paddingRight="@dimen/menu_button_padding_h"
                android:text="@string/menu_ajouter_joueur"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/menu_button_text_size" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnHistorique"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_btn_selector"
                android:backgroundTint="@null"
                android:fontFamily="serif"
                android:paddingLeft="@dimen/menu_button_padding_h"
                android:paddingRight="@dimen/menu_button_padding_h"
                android:text="@string/menu_historique"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/menu_button_text_size" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnStatistiques"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_btn_selector"
                android:backgroundTint="@null"
                android:fontFamily="serif"
                android:paddingLeft="@dimen/menu_button_padding_h"
                android:paddingRight="@dimen/menu_button_padding_h"
                android:text="@string/menu_statistiques"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/menu_button_text_size" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnParametres"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_selector"
                android:backgroundTint="@null"
                android:fontFamily="serif"
                android:paddingLeft="@dimen/menu_button_padding_h"
                android:paddingRight="@dimen/menu_button_padding_h"
                android:text="@string/menu_parametres"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/menu_button_text_size" />

        </LinearLayout>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/fragmentContainerView"
            android:name="androidx.navigation.fragment.NavHostFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:defaultNavHost="true"
            app:layout_constraintBottom_toTopOf="@id/gBottom"
            app:layout_constraintEnd_toStartOf="@id/gContentEnd"
            app:layout_constraintStart_toStartOf="@id/gContentStart"
            app:layout_constraintTop_toTopOf="@id/gTop"
            app:navGraph="@navigation/nav_menu_graph" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
