<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/backbois2" />

    <com.example.duckpuck.AssetPanelLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:assetInsetStyle="wood_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/historique_des_matches"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/historique_header_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAucunePartie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/aucune_partie_jou_e_pour_le_moment"
                android:textColor="#CCCCCC"
                android:visibility="gone" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <LinearLayout
                    android:id="@+id/listeParties"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

            </ScrollView>

        </LinearLayout>

    </com.example.duckpuck.AssetPanelLayout>
</FrameLayout>
