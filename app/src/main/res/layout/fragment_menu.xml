<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent">
    <ImageView android:id="@+id/imageView2" android:layout_width="match_parent" android:layout_height="match_parent" android:scaleType="centerCrop" android:src="@drawable/chatgpt_image_18_mai_2026__15_13_41"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:gravity="center" android:paddingLeft="60dp" android:paddingRight="60dp" android:paddingTop="40dp" android:paddingBottom="40dp">
        <!--  Conteneur des 3 colonnes égales  -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="horizontal" android:weightSum="3">
            <!--  ════════════════════════════════════════════════
                             COLONNE 1 — MENU LATÉRAL
                             ════════════════════════════════════════════════  -->
            <LinearLayout
                android:id="@+id/menuLateral"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_menu_border"
                android:elevation="6dp"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <Button
                    android:id="@+id/btnJouer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="#2196F3"
                    android:fontFamily="serif"
                    android:text="Jouer"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnAjouterJoueur"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="#C8A84B"
                    android:fontFamily="serif"
                    android:text="Ajouter un joueur"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnHistorique"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="#C8A84B"
                    android:fontFamily="serif"
                    android:text="Historique des parties"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnStatistiques"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginBottom="5dp"
                    android:layout_weight="1"
                    android:backgroundTint="#C8A84B"
                    android:fontFamily="serif"
                    android:text="Statistiques"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btnParametres"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:backgroundTint="#2196F3"
                    android:fontFamily="serif"
                    android:text="Paramètres"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />
            </LinearLayout>
            <!--  ════════════════════════════════════════════════
                             COLONNE 2 — CARTE 1 VS 1
                             ════════════════════════════════════════════════  -->
            <androidx.fragment.app.FragmentContainerView
                android:id="@+id/fragmentContainerView"
                android:name="androidx.navigation.fragment.NavHostFragment"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_weight="1"
                app:defaultNavHost="true"
                app:navGraph="@navigation/nav_menu_graph" />

            <!--  ════════════════════════════════════════════════
                             COLONNE 3 — CARTE 2 VS 2
                             ════════════════════════════════════════════════  -->
        </LinearLayout>
    </LinearLayout>
</FrameLayout>