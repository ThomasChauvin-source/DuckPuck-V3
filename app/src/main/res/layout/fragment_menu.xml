<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A009688">

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        app:srcCompat="@drawable/backbois2" />

    <com.example.duckpuck.AssetPanelLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:assetInsetStyle="wood_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="serif"
                android:text="@string/duck_puck"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/home_title_text_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/menu_hint"
                android:textColor="#CCFFFFFF"
                android:textSize="@dimen/subtitle_text_size" />
        </LinearLayout>

    </com.example.duckpuck.AssetPanelLayout>
</FrameLayout>
