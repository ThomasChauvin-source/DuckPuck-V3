<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitXY"
        android:src="@drawable/backbois2" />

    <com.example.duckpuck.AssetPanelLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:assetInsetStyle="wood_panel">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="serif"
                android:gravity="center"
                android:text="@string/nouveau_joueur"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/nom_du_joueur"
                android:textColor="#FFFFFF"
                android:textSize="@dimen/body_text_size" />

            <EditText
                android:id="@+id/editNomJoueur"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:backgroundTint="#FFFFFF"
                android:hint="Nouveau Joueur"
                android:inputType="textCapWords"
                android:textColor="#FFFFFF"
                android:textColorHint="#AAFFFFFF" />

            <Button
                android:id="@+id/btnConfirmerAjout"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:backgroundTint="#2196F3"
                android:text="@string/valider"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />

        </LinearLayout>

    </com.example.duckpuck.AssetPanelLayout>
</FrameLayout>
